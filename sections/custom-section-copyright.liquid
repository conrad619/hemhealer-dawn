<div class='color-{{ section.settings.color_scheme }} twcss-overflow-hidden twcss-text-white lg:twcss-text-[1.8rem] twcss-text-[1.5rem] twcss-text-center twcss-py-[2rem] twcss-relative twcss-bg-[--accent-color]'>
  <div class='custom-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding'>
    <div
      {% if section.settings.full_width %}
        class='page-width'
      {% endif %}
    >
      <p>
        {{ 'sections.footer.statement_1' | t }}
      </p>
      <br>
      <p>
        {{ 'sections.footer.statement_2' | t }}
      </p>
      <br>
      <p>© 2026 Hem Healer&reg;, LLC. All rights reserved.</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "custom section copyright",
  "settings": [
