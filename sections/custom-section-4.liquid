<div class='color-{{ section.settings.color_scheme }} twcss-overflow-hidden twcss-relative lg:twcss-pt-[10rem] twcss-pt-[5rem] lg:twcss-pb-[10rem] twcss-pb-[5rem]'>
  <div
    class='twcss-left-0 twcss-overflow-hidden twcss-absolute twcss-w-full twcss-leading-none twcss-top-0 twcss-rotate-180'
  >
    <svg
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 1000 100'
      preserveAspectRatio='none'
      class='lg:twcss-w-[calc(142%+1.3px)] twcss-w-[calc(210%+1.3px)] lg:twcss-h-[17.8rem] twcss-h-[5.9rem] twcss-relative twcss-left-1/2 -twcss-translate-x-1/2 twcss-fill-[--accent-color-3]'
    >
      <path class="elementor-shape-fill" d="M790.5,93.1c-59.3-5.3-116.8-18-192.6-50c-29.6-12.7-76.9-31-100.5-35.9c-23.6-4.9-52.6-7.8-75.5-5.3
      c-10.2,1.1-22.6,1.4-50.1,7.4c-27.2,6.3-58.2,16.6-79.4,24.7c-41.3,15.9-94.9,21.9-134,22.6C72,58.2,0,25.8,0,25.8V100h1000V65.3
      c0,0-51.5,19.4-106.2,25.7C839.5,97,814.1,95.2,790.5,93.1z"></path>
    </svg>
  </div>
  <div class='custom-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding'>
    <div
      {% if section.settings.full_width %}
        class='page-width'
      {% endif %}
    >
      <div class='twcss-flex lg:twcss-flex-nowrap twcss-flex-wrap twcss-gap-[4rem]'>
        <div class='lg:twcss-text-left twcss-text-center lg:twcss-order-1 twcss-order-2 twcss-flex twcss-gap-[2rem] twcss-flex-col lg:twcss-w-1/2 twcss-w-full twcss-justify-center'>
          <h2 class='lg:twcss-block twcss-hidden lg:twcss-text-[7rem] twcss-text-[4.5rem] twcss-font-medium twcss-leading-none'>
            {{ section.settings.heading_text }}
          </h2>
          {% comment %}
            <h3 class='lg:twcss-text-[4.5rem] twcss-text-[2.5rem] twcss-font-medium twcss-text-[--secondary-color] lg:twcss-leading-[5.4rem]'>
              We Understand Your Pain – Because We’ve Been There
            </h3>
          {% endcomment %}
          <p class='lg:twcss-text-[1.8rem] twcss-text-[1.5rem]'>
            {{ section.settings.description_1_text }}
          </p>
          <p class='lg:twcss-text-[1.8rem] twcss-text-[1.5rem]'>
            {{ section.settings.description_2_text }}
          </p>
          <div class=''>
            <a
              href='{{ routes.root_url | append: '/pages/about' | replace: '//', '/' }}'
              class='twcss-text-[--accent-color] twcss-inline-flex twcss-font-semibold twcss-items-center lg:twcss-text-[2rem] twcss-text-[1.6rem] twcss-font-heading twcss-border-b twcss-border-[--accent-color]'
              ><span>{{ section.settings.link_story_text }}</span>
              <svg
                class='material-symbols-outlined twcss-w-[2rem] twcss-h-[2rem] twcss-ml-[1rem]'
                xmlns='http://www.w3.org/2000/svg'
                height='24px'
                viewBox='0 -960 960 960'
                width='24px'
                fill='#3D8124'
              >
                <path d="M100-240v-480l360 240-360 240Zm400 0v-480l360 240-360 240Z"/>
              </svg>
            </a>
          </div>
          <div>
            <a
              href='{{ routes.root_url | append: '/pages/about#where-is-made' | replace: '//', '/' }}'
              class='twcss-text-[--accent-color] twcss-inline-flex twcss-font-semibold twcss-items-center lg:twcss-text-[2rem] twcss-text-[1.6rem] twcss-font-heading twcss-border-b twcss-border-[--accent-color]'
              ><span>{{ section.settings.link_manufactured_text }}</span>
              <svg
                class='material-symbols-outlined twcss-w-[2rem] twcss-h-[2rem] twcss-ml-[1rem]'
                xmlns='http://www.w3.org/2000/svg'
                height='24px'
                viewBox='0 -960 960 960'
                width='24px'
                fill='#3D8124'
              >
                <path d="M100-240v-480l360 240-360 240Zm400 0v-480l360 240-360 240Z"/>
              </svg>
            </a>
          </div>
        </div>
        <div class='lg:twcss-w-1/2 twcss-w-full lg:twcss-order-2 twcss-order-1'>
          <h2 class='lg:twcss-hidden twcss-block twcss-text-center lg:twcss-text-[7rem] twcss-text-[4.5rem] twcss-font-medium twcss-leading-none  twcss-mb-[4rem]'>
            {{ section.settings.heading_text }}
          </h2>

          {%- assign cs4_image_src = 'https://cdn.shopify.com/s/files/1/0550/1560/4383/files/Ian_Gutoskie.jpg?v=1745360498' -%}
          {%- if section.settings.image != blank -%}
            {%- assign cs4_image_src = section.settings.image | image_url: width: 1200 -%}
          {%- endif -%}

          <img
            src='{{ cs4_image_src }}'
            alt='{{ section.settings.image_alt }}'
            width='auto'
            height='auto'
          >
        </div>
      </div>
    </div>
  </div>
  <div
    class='twcss-left-0 twcss-overflow-hidden twcss-absolute twcss-w-full twcss-leading-none twcss-bottom-0 twcss-z-[-1] twcss-rotate-180'
  >
    <svg
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 1000 100'
      preserveAspectRatio='none'
      class='twcss-w-[calc(100%+1.3px)] twcss-relative twcss-left-1/2 -twcss-translate-x-1/2 twcss-fill-[#C6E1231F]'
    >
      <path class="elementor-shape-fill" d="M421.9,6.5c22.6-2.5,51.5,0.4,75.5,5.3c23.6,4.9,70.9,23.5,100.5,35.7c75.8,32.2,133.7,44.5,192.6,49.7
      c23.6,2.1,48.7,3.5,103.4-2.5c54.7-6,106.2-25.6,106.2-25.6V0H0v30.3c0,0,72,32.6,158.4,30.5c39.2-0.7,92.8-6.7,134-22.4
      c21.2-8.1,52.2-18.2,79.7-24.2C399.3,7.9,411.6,7.5,421.9,6.5z"></path>
    </svg>
  </div>
</div>

{% schema %}
{
  "name": "custom section IV",
  "settings": [
    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading",
      "default": "t:sections.custom-section-4.settings.heading_text.default"
    },
    {
      "type": "textarea",
      "id": "description_1_text",
      "label": "Description 1",
      "default": "t:sections.custom-section-4.settings.description_1_text.default"
    },
    {
      "type": "textarea",
      "id": "description_2_text",
      "label": "Description 2",
      "default": "t:sections.custom-section-4.settings.description_2_text.default"
    },
    {
      "type": "text",
      "id": "link_story_text",
      "label": "Link: Our Story",
      "default": "t:sections.custom-section-4.settings.link_story_text.default"
    },
    {
      "type": "text",
      "id": "link_manufactured_text",
      "label": "Link: Manufactured",
      "default": "t:sections.custom-section-4.settings.link_manufactured_text.default"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Hero Image Alt Text",
      "default": "t:sections.custom-section-4.settings.image_alt.default"
    }
  ],
  "presets": [
    {
      "name": "custom section IV"
    }
  ]
}
{% endschema %}
