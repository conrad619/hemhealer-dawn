<div class='color-{{ section.settings.color_scheme }} twcss-overflow-hidden twcss-relative twcss-bg-[--accent-color] twcss-pb-[15rem] twcss-bg-[top_center]'>
  <div class='custom-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding'>
    <div
      {% if section.settings.full_width %}
        class='page-width'
      {% endif %}
    >
      <div class='twcss-flex twcss-flex-col twcss-gap-[2rem]'>
        <h2 class='lg:twcss-text-[7rem] twcss-text-[4.5rem]  twcss-pt-[5rem] twcss-pb-[4rem] twcss-font-medium twcss-text-center twcss-text-[--accent-color-2] twcss-leading-none'>
          {{ section.settings.heading_text }}
        </h2>
        <div class='twcss-flex lg:twcss-flex-row twcss-flex-col twcss-gap-[4rem] '>
          <div class='twcss-bg-white twcss-flex twcss-flex-col lg:twcss-gap-[4rem] twcss-gap-[2rem] lg:twcss-px-[4rem] twcss-px-[2rem] lg:twcss-pt-[4rem] twcss-pt-[2rem] lg:twcss-pb-[6rem] twcss-pb-[4rem] lg:twcss-w-1/2 twcss-w-full twcss-shadow-[0px_0px_10px_0px_rgba(0,0,0,0.5)]'>
            <h3 class='lg:twcss-text-[4.5rem] twcss-text-[3.5rem]  twcss-font-medium twcss-leading-none'>
              {{ section.settings.card_1_title }}
            </h3>
            <h4 class='lg:twcss-text-[2.6rem] twcss-text-[2.2rem] twcss-font-bold twcss-text-[--secondary-color] twcss-underline twcss-font-body twcss-leading-none'>
              {{ section.settings.card_1_subtitle }}
            </h4>
            {%- assign cs9_card1_src = 'https://cdn.shopify.com/s/files/1/0550/1560/4383/files/HH_EFF.png?v=1745586334' -%}
            {%- if section.settings.card_1_image != blank -%}
              {%- assign cs9_card1_src = section.settings.card_1_image | image_url: width: 800 -%}
            {%- endif -%}
            <img
              src='{{ cs9_card1_src }}'
              alt='{{ section.settings.card_1_image_alt }}'
              width='auto'
              height='auto'
            >
            <p class='twcss-my-[1.8rem] lg:twcss-text-[1.8rem] twcss-text-[1.5rem] twcss-text-black'>
              {{ section.settings.card_1_copy }}
            </p>
            <a
              href='{{ routes.root_url | append: '/products/heroic-combo-pack' | replace: '//', '/' }}'
              class='twcss-font-heading lg:twcss-text-[1.8rem] twcss-text-[1.5rem] twcss-rounded-[.3rem] twcss-text-white twcss-text-center twcss-font-semibold twcss-py-[.6rem] twcss-px-[2rem] twcss-bg-[--accent-color] hover:twcss-scale-[.9] twcss-transition-all '
            >
              {{- section.settings.card_1_cta | strip_newlines -}}
            </a>
          </div>
          <div class='twcss-bg-white twcss-flex twcss-flex-col lg:twcss-gap-[4rem] twcss-gap-[2rem] lg:twcss-px-[4rem] twcss-px-[2rem] lg:twcss-pt-[4rem] twcss-pt-[2rem] lg:twcss-pb-[6rem] twcss-pb-[4rem] lg:twcss-w-1/2 twcss-w-full twcss-shadow-[0px_0px_10px_0px_rgba(0,0,0,0.5)]'>
            <h3 class='lg:twcss-text-[4.5rem] twcss-text-[3.5rem]  twcss-font-medium twcss-leading-none'>
              {{ section.settings.card_2_title }}
            </h3>
            <h4 class='lg:twcss-text-[2.6rem] twcss-text-[2.2rem] twcss-font-bold twcss-text-[--secondary-color] twcss-underline twcss-font-body twcss-leading-none'>
              {{ section.settings.card_2_subtitle }}
            </h4>
            {%- assign cs9_card2_src = 'https://cdn.shopify.com/s/files/1/0550/1560/4383/files/HR_EFF.png?v=1745586334' -%}
            {%- if section.settings.card_2_image != blank -%}
              {%- assign cs9_card2_src = section.settings.card_2_image | image_url: width: 800 -%}
            {%- endif -%}
            <img
              src='{{ cs9_card2_src }}'
              alt='{{ section.settings.card_2_image_alt }}'
              width='auto'
              height='auto'
            >
            <p class='twcss-my-[1.8rem] lg:twcss-text-[1.8rem] twcss-text-[1.5rem] twcss-text-black'>
              {{ section.settings.card_2_copy }}
            </p>
            <a
              href='{{ routes.root_url | append: '/products/prevention-power-pack' | replace: '//', '/' }}'
              class='twcss-font-heading lg:twcss-text-[1.8rem] twcss-text-[1.5rem] twcss-rounded-[.3rem] twcss-text-white twcss-text-center twcss-font-semibold twcss-py-[.6rem] twcss-px-[2rem] twcss-bg-[--accent-color] hover:twcss-scale-[.9] twcss-transition-all '
            >
              {{- section.settings.card_2_cta | strip_newlines -}}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "custom section IX",
  "settings": [
    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading",
      "default": "t:sections.custom-section-9.settings.heading_text.default"
    },
    {
      "type": "textarea",
      "id": "card_1_title",
      "label": "Card 1 Title",
      "default": "t:sections.custom-section-9.settings.card_1_title.default"
    },
    {
      "type": "textarea",
      "id": "card_1_subtitle",
      "label": "Card 1 Subtitle",
      "default": "t:sections.custom-section-9.settings.card_1_subtitle.default"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Card 1 Image"
    },
    {
      "type": "text",
      "id": "card_1_image_alt",
      "label": "Card 1 Image Alt",
      "default": "t:sections.custom-section-9.settings.card_1_image_alt.default"
    },
    {
      "type": "textarea",
      "id": "card_1_copy",
      "label": "Card 1 Copy",
      "default": "t:sections.custom-section-9.settings.card_1_copy.default"
    },
    {
      "type": "textarea",
      "id": "card_1_cta",
      "label": "Card 1 CTA",
      "default": "t:sections.custom-section-9.settings.card_1_cta.default"
    },
    {
      "type": "textarea",
      "id": "card_2_title",
      "label": "Card 2 Title",
      "default": "t:sections.custom-section-9.settings.card_2_title.default"
    },
    {
      "type": "textarea",
      "id": "card_2_subtitle",
      "label": "Card 2 Subtitle",
      "default": "t:sections.custom-section-9.settings.card_2_subtitle.default"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Card 2 Image"
    },
    {
      "type": "text",
      "id": "card_2_image_alt",
      "label": "Card 2 Image Alt",
      "default": "t:sections.custom-section-9.settings.card_2_image_alt.default"
    },
    {
      "type": "textarea",
      "id": "card_2_copy",
      "label": "Card 2 Copy",
      "default": "t:sections.custom-section-9.settings.card_2_copy.default"
    },
    {
      "type": "textarea",
      "id": "card_2_cta",
      "label": "Card 2 CTA",
      "default": "t:sections.custom-section-9.settings.card_2_cta.default"
    }
  ],
  "presets": [
    {
      "name": "custom section IX"
    }
  ]
}
{% endschema %}
