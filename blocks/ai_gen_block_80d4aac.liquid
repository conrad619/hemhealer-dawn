{% doc %}
  @prompt
    make a featured collection except I can choose which products to display and can assign links for each, style should be like the existing featured collection, make it look like the featured collection, it has rating the heading the metiafields subheading price same size same font, revert to the first version
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-product-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-custom-product-grid__inner-{{ ai_gen_id }} {
    padding-top: calc({{ block.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ block.settings.padding_bottom }}px * 0.75);
  }

  @media screen and (min-width: 750px) {
    .ai-custom-product-grid__inner-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }
  }

  .ai-custom-product-grid__header-{{ ai_gen_id }} {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .ai-custom-product-grid__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-custom-product-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.spacing }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (min-width: 750px) {
    .ai-custom-product-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .ai-custom-product-grid__card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-custom-product-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-custom-product-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-custom-product-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-custom-product-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-custom-product-grid__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-custom-product-grid__info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-custom-product-grid__product-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-custom-product-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 500;
    color: {{ block.settings.price_color }};
  }

  .ai-custom-product-grid__empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    color: #999;
    font-style: italic;
  }
{% endstyle %}

<div class="ai-custom-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-product-grid__inner-{{ ai_gen_id }} page-width">
    {% if block.settings.title != blank %}
      <div class="ai-custom-product-grid__header-{{ ai_gen_id }}">
        <h2 class="ai-custom-product-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      </div>
    {% endif %}

    <ul class="ai-custom-product-grid__grid-{{ ai_gen_id }}">
      {% liquid
        assign has_products = false
        for i in (1..8)
          assign product_key = 'product_' | append: i
          assign product = block.settings[product_key]
          
          if product != blank
            assign has_products = true
          endif
        endfor
      %}

      {% if has_products %}
        {% for i in (1..8) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign link_key = 'product_' | append: i | append: '_link'
            assign product = block.settings[product_key]
            assign custom_link = block.settings[link_key]
          %}

          {% if product != blank %}
            {% if custom_link != blank %}
              {% assign product_url = custom_link %}
            {% else %}
              {% assign product_url = product.url %}
            {% endif %}

            <li>
              <a href="{{ product_url }}" class="ai-custom-product-grid__card-{{ ai_gen_id }} card-wrapper product-card-wrapper underline-links-hover twcss-p-[1.6rem] twcss-shadow-[0_1px_2px_0_#0000000d] twcss-rounded-[.8rem]  twcss-border-[#eaecf0] twcss-border">
                <h2 class='twcss-text-[2rem] twcss-text-center twcss-font-bold'>
                  {{ product.metafields.custom.product_headline }}
                </h2>
                <div class="ai-custom-product-grid__image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-custom-product-grid__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                    >
                  {% else %}
                    <div class="ai-custom-product-grid__placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-custom-product-grid__info-{{ ai_gen_id }}">
                
                  <!-- RYVIU APP :: COLLECTION-WIDGET-TOTAL -->
                  <div class='ryviu-collection'>
                    <ryviu-widget-total
                      collection='1'
                      reviews_data='{{ product.metafields.ryviu.product_reviews_info  | escape  }}'
                      product_id='{{ product.id }}'
                      handle='{{ product.handle }}'
                    ></ryviu-widget-total>
                  </div>
                  <!-- RYVIU APP -->
                  <h3 class="ai-custom-product-grid__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <h4 class='twcss-text-[1.4rem] twcss-font-body twcss-py-[1rem]'>
                    {{ product.metafields.custom.product_subheadline }}
                  </h4>
                  {% if block.settings.show_price %}
                    <div class='card-information'>
                      {% render 'price', product: product, price_class: '', show_compare_at_price: true %}
                    </div>
                  {% endif %}
                </div>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-custom-product-grid__empty-state-{{ ai_gen_id }}">
          Next, select products to display in this collection
        </div>
      {% endif %}
    </ul>
  </div>
</div>

