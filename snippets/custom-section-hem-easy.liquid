        <style>
          .accordion-header {
            padding: 2rem 2rem 2.4rem 4rem;
            width: 100%;
            text-align: left;
            cursor: pointer;
            font-weight: bold;
            border-bottom: 1px solid #000;
            transition: background 0.3s;
            font-size: 1.8rem;
            color: #000;
            position: relative;
          }

          .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease;
          }

          .accordion-inner {
            padding: 2rem 0 2rem 4rem;
          }

          .accordion-header:after {
            content: '+';
            font-size: 2.4rem;
            position: absolute;
            left: 1rem;
            line-height: 2.6rem;
          }
          .accordion-header.active:after {
            content: '-';
          }
          @media (max-width: 990px) {
            .accordion-header {
              font-size: 1.5rem;
            }
            .accordion-header:after {
              content: '+';
              font-size: 2.4rem;
              left: 1rem;
              line-height: 2.6rem;
              top: 1.7rem;
            }
          }
        </style>

