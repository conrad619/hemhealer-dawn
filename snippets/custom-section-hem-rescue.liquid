<div
  id='videoModal'
  class='twcss-fixed twcss-inset-0 twcss-bg-black/80 twcss-z-50 twcss-items-center twcss-justify-center twcss-hidden twcss-flex'
  onclick='closeVideoModal()'
>
  <div class='twcss-relative twcss-w-full twcss-max-w-[120rem] twcss-aspect-video twcss-bg-black'>
    <iframe
      id='videoIframe'
      class='twcss-w-full twcss-h-full'
      src=''
      frameborder='0'
      allow='autoplay; fullscreen'
      allowfullscreen
    ></iframe>
    <button
      onclick='closeVideoModal()'
      class='twcss-absolute twcss-top-2 twcss-right-2 twcss-text-black twcss-bg-white twcss-rounded-full twcss-w-8 twcss-h-8 twcss-flex twcss-items-center twcss-justify-center'
    >
      ✕
    </button>
  </div>
</div>
<script>
  function openVideoModal(videoUrl) {
    const modal = document.getElementById('videoModal');
    const iframe = document.getElementById('videoIframe');
    iframe.src = videoUrl + '&autoplay=1';
    modal.classList.remove('twcss-hidden');
  }

  function closeVideoModal() {
    const modal = document.getElementById('videoModal');
    const iframe = document.getElementById('videoIframe');
    iframe.src = '';
    modal.classList.add('twcss-hidden');
  }

  // comparison
  let comparisonData = [
    '{{ 'custom_section_hem_rescue.comparison_item_1' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_2' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_3' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_4' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_5' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_6' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_7' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_8' | t }}',
    '{{ 'custom_section_hem_rescue.comparison_item_9' | t }}',
  ];
  const comparisonContainer = document.getElementById('comparison');

  comparisonData.forEach((content, i) => {
    const item = document.createElement('div');
    item.className = 'twcss-flex twcss-flex-row';
    item.innerHTML = `
        <div class='${
          comparisonData.length - 1 == i ? '' : 'twcss-border-b'
        } twcss-border-gray-400 twcss-flex-grow lg:twcss-py-[1rem] lg:twcss-px-[2rem] twcss-p-[.5rem] twcss-font-bold lg:twcss-text-[1.8rem] twcss-text-[1.2rem]'>
