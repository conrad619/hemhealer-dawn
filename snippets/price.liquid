{% comment %}
  Renders a list of product's price (regular, sale)

  Accepts:
  - product: {Object} Product Liquid object (optional)
  - placeholder: {Boolean} Renders a placeholder price (optional)
  - use_variant: {Boolean} Renders selected or first variant price instead of overall product pricing (optional)
  - show_badges: {Boolean} Renders 'Sale' and 'Sold Out' tags if the product matches the condition (optional)
  - price_class: {String} Adds a price class to the price element (optional)
  - show_compare_at_price: {Boolean} Renders the compare at price if the product matches the condition (optional)

  Usage:
  {% render 'price', product: product %}
{% endcomment %}
{%- liquid
  if use_variant
    assign target = product.selected_or_first_available_variant
  elsif placeholder
    assign target = null
  else
    assign target = product
  endif

  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign price_min = product.price_min
  assign price_max = product.price_max
  assign available = target.available | default: false
  assign money_price = price | money
  assign money_price_min = price_min | money
  assign money_price_max = price_max | money
  if settings.currency_code_enabled
    assign money_price = price | money_with_currency
    assign money_price_min = price_min | money_with_currency
    assign money_price_max = price_max | money_with_currency
  endif

  if target == product and product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
  endif
-%}

{%- unless target == null and placeholder == null -%}
  <div
    class='
      price
      {%- if price_class %} {{ price_class }}{% endif -%}
      {%- if available == false %} price--sold-out{% endif -%}
      {%- if compare_at_price > price and product.quantity_price_breaks_configured? != true %} price--on-sale{% endif -%}
      {%- if compare_at_price > price and product.quantity_price_breaks_configured? %} volume-pricing--sale-badge{% endif -%}
      {%- if product.price_varies == false and product.compare_at_price_varies %} price--no-compare{% endif -%}
      {%- if show_badges %} price--show-badge{% endif -%}
    '
  >
    <div class='price__container'>
      {%- comment -%}
        Explanation of description list:
          - div.price__regular: Displayed when there are no variants on sale
          - div.price__sale: Displayed when a variant is a sale
      {%- endcomment -%}
      <div class='price__regular'>
        {%- if product.quantity_price_breaks_configured? -%}
          {%- if show_compare_at_price and compare_at_price -%}
            {%- unless product.price_varies == false and product.compare_at_price_varies %}
              <span class='visually-hidden visually-hidden--inline'>
                {{- 'products.product.price.regular_price' | t -}}
              </span>
              <span>
                <s class='price-item price-item--regular variant-item__old-price'>
                  {% if settings.currency_code_enabled %}
                    {{ compare_at_price | money_with_currency }}
                  {% else %}
                    {{ compare_at_price | money }}
                  {% endif %}
                </s>
              </span>
            {%- endunless -%}
          {%- endif -%}
          <span class='visually-hidden visually-hidden--inline'>{{ 'products.product.price.regular_price' | t }}</span>
          <span class='price-item price-item--regular'>
            {{-
              'products.product.volume_pricing.price_range'
              | t: minimum: money_price_min, maximum: money_price_max
            -}}
          </span>
        {%- else -%}
          <span class='visually-hidden visually-hidden--inline'>{{ 'products.product.price.regular_price' | t }}</span>
          <span class='price-item price-item--regular'>
            {{ money_price }}
          </span>
        {%- endif -%}
      </div>
      <div class='price__sale'>
        {%- unless product.price_varies == false and product.compare_at_price_varies %}
          <span class='visually-hidden visually-hidden--inline'>{{ 'products.product.price.regular_price' | t }}</span>
          <span>
            <s class='price-item price-item--regular price__compare'>
              {% if settings.currency_code_enabled %}
                {{ compare_at_price | money_with_currency }}
              {% else %}
                {{ compare_at_price | money }}
              {% endif %}
            </s>
          </span>
        {%- endunless -%}
        <span class='visually-hidden visually-hidden--inline'>{{ 'products.product.price.sale_price' | t }}</span>
        <span class='price-item price-item--sale price-item--last'>
          {{ money_price }}
        </span>
      </div>
      <small class='unit-price caption{% if product.selected_or_first_available_variant.unit_price_measurement == nil %} hidden{% endif %}'>
        <span class='visually-hidden'>{{ 'products.product.price.unit_price' | t }}</span>
        <span class='price-item price-item--last'>
          <span>{{- product.selected_or_first_available_variant.unit_price | money -}}</span>
          <span aria-hidden='true'>/</span>
          <span class='visually-hidden'>&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
          <span>
            {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
              {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
            {%- endif -%}
            {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
          </span>
        </span>
      </small>
    </div>
    {% comment %}
      {%- if show_badges -%}
        <span class='badge price__badge-sale color-{{ settings.sale_badge_color_scheme }}'>
          {{ 'products.product.on_sale' | t }}
        </span>

        <span class='badge price__badge-sold-out color-{{ settings.sold_out_badge_color_scheme }}'>
          {{ 'products.product.sold_out' | t }}
        </span>
      {%- endif -%}
    {% endcomment %}
  </div>
{% endunless %}

<script>
  if (!window.hemhealerRechargePriceInitialized) {
    window.hemhealerRechargePriceInitialized = true;

    document.addEventListener('DOMContentLoaded', function () {
      const RECHARGE_WIDGET_HOST_SELECTOR = 'recharge-subscription-widget';
      const RECHARGE_WIDGET_SELECTOR = '.rc-widget__root';
      const RECHARGE_INPUT_SELECTOR =
        '.rc-purchase-option__input[name="purchaseOption"]';

      function extractPrice(text) {
        return parseFloat((text || '').replace(/[^0-9.]/g, '')) || 0;
      }

      function formatMoney(amount, template = '$0.00') {
        const formattedAmount = amount.toFixed(2);
        const numberMatch = template.match(/[0-9][0-9,]*(?:\.[0-9]+)?/);

        if (numberMatch) {
          return template.replace(numberMatch[0], formattedAmount);
        }

        return `$${formattedAmount}`;
      }

      function getPriceWrapper() {
        return (
          document.querySelector('product-info[id^="MainProduct"] [id^="price-"] .price') ||
          document.querySelector('.product__info-container [id^="price-"] .price') ||
          document.querySelector('.product__info-container .price')
        );
      }

      function getRechargeHost() {
        return document.querySelector(RECHARGE_WIDGET_HOST_SELECTOR);
      }

      function getRechargeQueryRoot() {
        return getRechargeHost()?.shadowRoot || document;
      }

      function queryRecharge(selector) {
        const root = getRechargeQueryRoot();
        const result = root.querySelector(selector);

        if (result || root === document) return result;

        return document.querySelector(selector);
      }

      function getRechargeWidget() {
        return queryRecharge(RECHARGE_WIDGET_SELECTOR);
      }

      function getCurrentPriceElements(priceWrapper) {
        return [
          priceWrapper.querySelector(
            '.price__regular .price-item--regular:not(.price__compare):not(.variant-item__old-price)',
          ),
          priceWrapper.querySelector('.price__sale .price-item--sale'),
        ].filter(Boolean);
      }

      function getBasePrice(priceWrapper) {
        const rechargeOneTimePrice = getRechargeOptionPrice('onetime');

        if (rechargeOneTimePrice > 0) {
          priceWrapper.dataset.originalPrice = rechargeOneTimePrice;
          return rechargeOneTimePrice;
        }

        const storedPrice = parseFloat(priceWrapper.dataset.originalPrice);
        if (storedPrice > 0) return storedPrice;

        const priceEl =
          priceWrapper.querySelector(
            '.price__regular .price-item--regular:not(.price__compare):not(.variant-item__old-price)',
          ) || priceWrapper.querySelector('.price__sale .price-item--sale');
        const basePrice = extractPrice(priceEl?.textContent);

        if (basePrice > 0) {
          priceWrapper.dataset.originalPrice = basePrice;
        }

        return basePrice;
      }

      function getRechargeOptionRoot(option) {
        if (option === 'subscription') {
          return queryRecharge(
            `${RECHARGE_WIDGET_SELECTOR} .rc-purchase-option__subscription`,
          );
        }

        return queryRecharge(
          `${RECHARGE_WIDGET_SELECTOR} .rc-selection__onetime, ${RECHARGE_WIDGET_SELECTOR} [part~="rc-purchase-option__onetime"]`,
        );
      }

      function getRechargeOptionPrice(option) {
        const optionRoot = getRechargeOptionRoot(option);
        if (!optionRoot) return 0;

        const selectors =
          option === 'subscription'
            ? [
                '[part~="rc-purchase-option__discounted-price"]',
                '.rc-purchase-option__prices .rc-price:not(.strike-through):not(.text-muted)',
              ]
            : [
                '[part~="rc-purchase-option__price"]',
                '.rc-purchase-option__prices .rc-price:not(.strike-through):not(.text-muted)',
              ];

        for (const selector of selectors) {
          const priceEl = optionRoot.querySelector(selector);
          const price = extractPrice(priceEl?.textContent);
          if (price > 0) return price;
        }

        return 0;
      }

      function getRechargeOriginalSubscriptionPrice() {
        const optionRoot = getRechargeOptionRoot('subscription');
        if (!optionRoot) return 0;

        return extractPrice(
          optionRoot.querySelector(
            '[part~="rc-purchase-option__original-price"], .rc-price.strike-through',
          )?.textContent,
        );
      }

      function getSelectedRechargeOption() {
        const checkedInput = queryRecharge(
          `${RECHARGE_WIDGET_SELECTOR} ${RECHARGE_INPUT_SELECTOR}:checked`,
        );
        if (checkedInput) return checkedInput.value;

        const selectedOption = queryRecharge(
          `${RECHARGE_WIDGET_SELECTOR} .rc-purchase-option[rc-selected]`,
        );
        if (selectedOption?.matches('.rc-purchase-option__subscription')) return 'subscription';
        if (selectedOption?.matches('.rc-selection__onetime, [part~="rc-purchase-option__onetime"]')) {
          return 'onetime';
        }

        return 'onetime';
      }

      function setSavings(priceWrapper, referencePrice, currentPrice) {
        let savingsEl = priceWrapper.querySelector('.price__savings');

        if (!savingsEl) {
          savingsEl = document.createElement('span');
          savingsEl.className = 'badge price__badge-sale color-scheme-5 price__savings';
          priceWrapper.appendChild(savingsEl);
        }

        const savings = referencePrice - currentPrice;
        if (savings > 0) {
          savingsEl.textContent = `Save $${savings.toFixed(2)}`;
          savingsEl.style.display = 'inline-block';
        } else {
          savingsEl.style.display = 'none';
        }
      }

      function updateDisplayedPrice(isSubscription) {
        const priceWrapper = getPriceWrapper();
        if (!priceWrapper) return false;

        const currentPriceEls = getCurrentPriceElements(priceWrapper);
        if (!currentPriceEls.length) return false;

        const basePrice = getBasePrice(priceWrapper);
        const rechargeSubscriptionPrice = getRechargeOptionPrice('subscription');
        const currentPrice =
          isSubscription && rechargeSubscriptionPrice > 0 ? rechargeSubscriptionPrice : basePrice;
        const moneyTemplate = currentPriceEls[0].textContent.trim() || '$0.00';
        const formattedPrice = formatMoney(currentPrice, moneyTemplate);

        currentPriceEls.forEach((priceEl) => {
          priceEl.textContent = formattedPrice;
        });

        const comparePrice = extractPrice(priceWrapper.querySelector('.price__compare')?.textContent);
        const subscriptionOriginalPrice = getRechargeOriginalSubscriptionPrice();
        const savingsReferencePrice =
          comparePrice || (isSubscription ? subscriptionOriginalPrice || basePrice : basePrice);

        setSavings(priceWrapper, savingsReferencePrice, currentPrice);
        document.querySelector('.product')?.classList.toggle('subscribe', isSubscription);

        return true;
      }

      function syncRechargePrice() {
        const widget = getRechargeWidget();
        if (!widget) {
          updateDisplayedPrice(false);
          return false;
        }

        updateDisplayedPrice(getSelectedRechargeOption() === 'subscription');
        observeRechargeWidget(widget);

        return true;
      }

      function queueRechargePriceSync() {
        [0, 150, 700].forEach((delay) => {
          window.setTimeout(syncRechargePrice, delay);
        });
      }

      function isRechargeTarget(target) {
        return (
          target.matches(RECHARGE_INPUT_SELECTOR) ||
          target.matches(RECHARGE_WIDGET_HOST_SELECTOR) ||
          target.closest(`${RECHARGE_WIDGET_SELECTOR} .rc-purchase-option__label`) ||
          target.closest(RECHARGE_WIDGET_HOST_SELECTOR)
        );
      }

      function handleRechargeInteraction(event) {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (isRechargeTarget(target)) {
          queueRechargePriceSync();
        }
      }

      function observeRechargeWidget(widget) {
        if (widget.dataset.hemhealerPriceObserved === 'true') return;

        widget.dataset.hemhealerPriceObserved = 'true';
        const widgetRoot = widget.getRootNode();

        if (widgetRoot && widgetRoot !== document && widgetRoot.addEventListener) {
          widgetRoot.addEventListener('change', handleRechargeInteraction);
          widgetRoot.addEventListener('click', handleRechargeInteraction);
        }

        new MutationObserver(queueRechargePriceSync).observe(widget, {
          attributes: true,
          attributeFilter: ['checked', 'rc-selected'],
          childList: true,
          characterData: true,
          subtree: true,
        });
      }

      document.addEventListener('change', function (event) {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (
          isRechargeTarget(target) ||
          target.closest('variant-selects') ||
          target.closest('.product-form')
        ) {
          queueRechargePriceSync();
        }
      });

      document.addEventListener('click', function (event) {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (isRechargeTarget(target)) {
          queueRechargePriceSync();
        }
      });

      let attempts = 0;
      const intervalId = window.setInterval(() => {
        attempts += 1;

        if (syncRechargePrice() || attempts >= 80) {
          window.clearInterval(intervalId);
        }
      }, 250);
    });
  }
</script>
