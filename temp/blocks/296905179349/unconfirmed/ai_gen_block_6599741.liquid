{% doc %}
  @prompt
    sticky top banner, can change color and text. add an option to show only on specific pages.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-banner-{{ ai_gen_id }} {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding }}px 20px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 1000;
    display: block;
  }

  .ai-sticky-banner-{{ ai_gen_id }}__content {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    font-size: {{ block.settings.font_size }}px;
  }

  .ai-sticky-banner-{{ ai_gen_id }}__content a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-sticky-banner-{{ ai_gen_id }}__content a:hover {
    opacity: 0.8;
  }
{% endstyle %}

<sticky-banner-{{ ai_gen_id }}
  class="ai-sticky-banner-{{ ai_gen_id }}"
  data-show-on="{{ block.settings.show_on }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-sticky-banner-{{ ai_gen_id }}__content">
    {{ block.settings.banner_text }}
  </div>
</sticky-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class StickyBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.showOn = this.getAttribute('data-show-on');
        this.checkVisibility();
      }

      checkVisibility() {
        const currentPath = window.location.pathname;

        if (this.showOn === 'all') {
          this.style.display = 'block';
          return;
        }

        if (this.showOn === 'home' && currentPath === '/') {
          this.style.display = 'block';
          return;
        }

        if (this.showOn === 'product' && currentPath.includes('/products/')) {
          this.style.display = 'block';
          return;
        }

        if (this.showOn === 'collection' && currentPath.includes('/collections/')) {
          this.style.display = 'block';
          return;
        }

        if (this.showOn === 'page' && currentPath.includes('/pages/')) {
          this.style.display = 'block';
          return;
        }

        this.style.display = 'none';
      }
    }

    customElements.define('sticky-banner-{{ ai_gen_id }}', StickyBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Sticky top banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "banner_text",
      "label": "Banner text",
      "default": "<p>Free shipping on orders over $50!</p>"
    },
    {
      "type": "select",
      "id": "show_on",
      "label": "Show on",
      "options": [
        {
          "value": "all",
          "label": "All pages"
        },
        {
          "value": "home",
          "label": "Home page only"
        },
        {
          "value": "product",
          "label": "Product pages only"
        },
        {
          "value": "collection",
          "label": "Collection pages only"
        },
        {
          "value": "page",
          "label": "Pages only"
        }
      ],
      "default": "all"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    }
  ],
  "presets": [
    {
      "name": "Sticky top banner"
    }
  ]
}
{% endschema %}
