{% doc %}
  @prompt
    sticky top banner, can change color and text. add an option to show only on specific pages., adjust to be fix top banner, and can only assign specific page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fixed-banner-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding }}px 20px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 1000;
    display: block;
  }

  .ai-fixed-banner-{{ ai_gen_id }}__content {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    font-size: {{ block.settings.font_size }}px;
  }

  .ai-fixed-banner-{{ ai_gen_id }}__content a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-fixed-banner-{{ ai_gen_id }}__content a:hover {
    opacity: 0.8;
  }
{% endstyle %}

<fixed-banner-{{ ai_gen_id }}
  class="ai-fixed-banner-{{ ai_gen_id }}"
  data-specific-page="{{ block.settings.specific_page }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-fixed-banner-{{ ai_gen_id }}__content">
    {{ block.settings.banner_text }}
  </div>
</fixed-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class FixedBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.specificPage = this.getAttribute('data-specific-page');
        this.checkVisibility();
      }

      checkVisibility() {
        if (!this.specificPage || this.specificPage.trim() === '') {
          this.style.display = 'block';
          return;
        }

        const currentPath = window.location.pathname;
        const normalizedCurrentPath = currentPath.replace(/^\/|\/$/g, '');
        const normalizedSpecificPage = this.specificPage.replace(/^\/|\/$/g, '');

        if (normalizedCurrentPath === normalizedSpecificPage) {
          this.style.display = 'block';
        } else {
          this.style.display = 'none';
        }
      }
    }

    customElements.define('fixed-banner-{{ ai_gen_id }}', FixedBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Fixed top banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "banner_text",
      "label": "Banner text",
      "default": "<p>Free shipping on orders over $50!</p>"
    },
    {
      "type": "text",
      "id": "specific_page",
      "label": "Specific page",
      "info": "Enter page path (e.g., pages/about or collections/all). Leave empty to show on all pages."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    }
  ],
  "presets": [
    {
      "name": "Fixed top banner"
    }
  ]
}
{% endschema %}
