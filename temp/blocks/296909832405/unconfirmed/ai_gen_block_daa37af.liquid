{% doc %}
  @prompt
    sticky banner at the very top of the page that canalso adjust color and text and can stay show up in above even when they scroll
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-banner-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding }}px 20px;
    text-align: {{ block.settings.text_alignment }};
    font-size: {{ block.settings.font_size }}px;
    display: block;
  }

  .ai-sticky-banner-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-sticky-banner-text-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-sticky-banner-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_underline }};
  }

  .ai-sticky-banner-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }
{% endstyle %}

<sticky-banner-{{ ai_gen_id }} class="ai-sticky-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sticky-banner-content-{{ ai_gen_id }}">
    {% if block.settings.banner_text != blank %}
      <p class="ai-sticky-banner-text-{{ ai_gen_id }}">
        {{ block.settings.banner_text }}
        {% if block.settings.link_text != blank and block.settings.link_url != blank %}
          <a href="{{ block.settings.link_url }}" class="ai-sticky-banner-link-{{ ai_gen_id }}">
            {{ block.settings.link_text }}
          </a>
        {% endif %}
      </p>
    {% endif %}
  </div>
</sticky-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class StickyBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustBodyPadding();
      }

      adjustBodyPadding() {
        const bannerHeight = this.offsetHeight;
        document.body.style.paddingTop = bannerHeight + 'px';
      }
    }

    customElements.define('sticky-banner-{{ ai_gen_id }}', StickyBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Sticky banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "banner_text",
      "label": "Banner text",
      "default": "Free shipping on orders over $50!"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#334fb4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#f3f3f3"
    },
    {
      "type": "select",
      "id": "link_underline",
      "label": "Link underline",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "underline",
          "label": "Underline"
        }
      ],
      "default": "underline"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    }
  ],
  "presets": [
    {
      "name": "Sticky banner"
    }
  ]
}
{% endschema %}
