{% doc %}
  @prompt
    make a featured collection except I can choose which products to display and can assign links for each, style should be like the existing featured collection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-product-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-custom-product-grid__inner-{{ ai_gen_id }} {
    padding-top: calc({{ block.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ block.settings.padding_bottom }}px * 0.75);
  }

  @media screen and (min-width: 750px) {
    .ai-custom-product-grid__inner-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }
  }

  .ai-custom-product-grid__header-{{ ai_gen_id }} {
    margin-bottom: 2.5rem;
  }

  .ai-custom-product-grid__title-{{ ai_gen_id }} {
    margin: 0;
    word-break: break-word;
  }

  .ai-custom-product-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, minmax(0, 1fr));
    column-gap: 1rem;
    row-gap: 3rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (min-width: 750px) {
    .ai-custom-product-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, minmax(0, 1fr));
      column-gap: var(--grid-desktop-horizontal-spacing);
      row-gap: var(--grid-desktop-vertical-spacing);
    }
  }

  .ai-custom-product-grid__card-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-custom-product-grid__card-{{ ai_gen_id }} {
    text-decoration: none;
    text-underline-offset: 0.3rem;
    display: block;
  }

  .ai-custom-product-grid__card-{{ ai_gen_id }}:hover .ai-custom-product-grid__card-title-{{ ai_gen_id }} {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  .ai-custom-product-grid__media-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-custom-product-grid__media-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    padding-bottom: 100%;
  }

  .ai-custom-product-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-custom-product-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-custom-product-grid__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-custom-product-grid__info-{{ ai_gen_id }} {
    padding-top: 1.5rem;
  }

  .ai-custom-product-grid__card-title-{{ ai_gen_id }} {
    margin: 0 0 0.5rem;
    word-break: break-word;
  }

  .ai-custom-product-grid__price-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
  }

  .ai-custom-product-grid__empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    color: rgba(var(--color-foreground), 0.55);
  }
{% endstyle %}

<div class="ai-custom-product-grid-{{ ai_gen_id }} color-{{ block.settings.color_scheme }} gradient" {{ block.shopify_attributes }}>
  <div class="ai-custom-product-grid__inner-{{ ai_gen_id }} page-width">
    {% if block.settings.title != blank %}
      <div class="ai-custom-product-grid__header-{{ ai_gen_id }} center">
        <h2 class="ai-custom-product-grid__title-{{ ai_gen_id }} {{ block.settings.heading_size }}">
          {{ block.settings.title }}
        </h2>
      </div>
    {% endif %}

    <ul class="ai-custom-product-grid__grid-{{ ai_gen_id }} grid grid--{{ block.settings.columns_mobile }}-col-tablet-down grid--{{ block.settings.columns_desktop }}-col-desktop">
      {% liquid
        assign has_products = false
        for i in (1..8)
          assign product_key = 'product_' | append: i
          assign product = block.settings[product_key]
          
          if product != blank
            assign has_products = true
          endif
        endfor
      %}

      {% if has_products %}
        {% for i in (1..8) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign link_key = 'product_' | append: i | append: '_link'
            assign product = block.settings[product_key]
            assign custom_link = block.settings[link_key]
          %}

          {% if product != blank %}
            {% if custom_link != blank %}
              {% assign product_url = custom_link %}
            {% else %}
              {% assign product_url = product.url %}
            {% endif %}

            <li class="ai-custom-product-grid__card-wrapper-{{ ai_gen_id }} grid__item">
              <div class="card-wrapper product-card-wrapper underline-links-hover">
                <a href="{{ product_url }}" class="ai-custom-product-grid__card-{{ ai_gen_id }} card card--{{ settings.card_style }} card--text">
                  <div class="card__inner color-{{ settings.card_color_scheme }} gradient ratio" style="--ratio-percent: 100%;">
                    <div class="ai-custom-product-grid__media-{{ ai_gen_id }} card__media media media--transparent">
                      {% if product.featured_image %}
                        <img
                          srcset="{{ product.featured_image | image_url: width: 165 }} 165w,
                                  {{ product.featured_image | image_url: width: 360 }} 360w,
                                  {{ product.featured_image | image_url: width: 533 }} 533w,
                                  {{ product.featured_image | image_url: width: 720 }} 720w,
                                  {{ product.featured_image | image_url: width: 940 }} 940w,
                                  {{ product.featured_image | image_url: width: 1066 }} 1066w"
                          src="{{ product.featured_image | image_url: width: 533 }}"
                          sizes="(min-width: 1440px) {{ 1440 | minus: 130 | divided_by: block.settings.columns_desktop }}px, (min-width: 990px) calc((100vw - 130px) / {{ block.settings.columns_desktop }}), (min-width: 750px) calc((100vw - 120px) / {{ block.settings.columns_desktop }}), calc((100vw - 35px) / {{ block.settings.columns_mobile }})"
                          alt="{{ product.featured_image.alt | escape }}"
                          class="ai-custom-product-grid__image-{{ ai_gen_id }} motion-reduce"
                          loading="lazy"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                        >
                      {% else %}
                        <div class="ai-custom-product-grid__placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>
                    <div class="ai-custom-product-grid__info-{{ ai_gen_id }} card__content">
                      <div class="card__information">
                        <h3 class="ai-custom-product-grid__card-title-{{ ai_gen_id }} card__heading h5">
                          {{ product.title }}
                        </h3>
                        {% if block.settings.show_price %}
                          <div class="ai-custom-product-grid__price-{{ ai_gen_id }} card-information">
                            <div class="price">
                              <div class="price__container">
                                <div class="price__regular">
                                  <span class="price-item price-item--regular">
                                    {{ product.price | money }}
                                  </span>
                                </div>
                              </div>
                            </div>
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </a>
              </div>
            </li>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-custom-product-grid__empty-state-{{ ai_gen_id }}">
          Next, select products to display in this collection
        </div>
      {% endif %}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Custom product grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Columns on desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
