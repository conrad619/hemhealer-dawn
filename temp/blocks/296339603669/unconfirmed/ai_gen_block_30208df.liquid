{% doc %}
  @prompt
    make a featured collection except I can choose which products to display and can assign links for each
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-product-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-custom-product-grid__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-custom-product-grid__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-custom-product-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-custom-product-grid__item-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: {{ block.settings.card_corner_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-custom-product-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-custom-product-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-custom-product-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-custom-product-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-custom-product-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-custom-product-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-custom-product-grid__product-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    line-height: 1.3;
  }

  .ai-custom-product-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 500;
  }

  .ai-custom-product-grid__empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-custom-product-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-custom-product-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-custom-product-grid__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-custom-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-custom-product-grid__header-{{ ai_gen_id }}">
      <h2 class="ai-custom-product-grid__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="ai-custom-product-grid__grid-{{ ai_gen_id }}">
    {% liquid
      assign has_products = false
      for i in (1..8)
        assign product_key = 'product_' | append: i
        assign link_key = 'product_' | append: i | append: '_link'
        assign product = block.settings[product_key]
        assign custom_link = block.settings[link_key]
        
        if product != blank
          assign has_products = true
        endif
      endfor
    %}

    {% if has_products %}
      {% for i in (1..8) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign link_key = 'product_' | append: i | append: '_link'
          assign product = block.settings[product_key]
          assign custom_link = block.settings[link_key]
        %}

        {% if product != blank %}
          {% if custom_link != blank %}
            {% assign product_url = custom_link %}
          {% else %}
            {% assign product_url = product.url %}
          {% endif %}

          <a href="{{ product_url }}" class="ai-custom-product-grid__item-{{ ai_gen_id }}">
            <div class="ai-custom-product-grid__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-custom-product-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-custom-product-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-custom-product-grid__content-{{ ai_gen_id }}">
              <h3 class="ai-custom-product-grid__product-title-{{ ai_gen_id }}">
                {{ product.title }}
              </h3>
              {% if block.settings.show_price %}
                <div class="ai-custom-product-grid__price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </div>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    {% else %}
      <div class="ai-custom-product-grid__empty-state-{{ ai_gen_id }}">
        Next, select products to display in this collection
      </div>
    {% endif %}
  </div>
</div>

