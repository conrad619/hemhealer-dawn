    "doctor_recommended_heading": "Doctor Recommended for Hemorrhoid Relief",
    "doctor_quote": "\"I highly recommend Hem Hero® for your hemorrhoids.\"",
    "doctor_name": "~ DR. LANGDON, M.D.",
    "alt_doctor": "doctor",
