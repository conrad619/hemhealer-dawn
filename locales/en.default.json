    "rating_text": "Rated 4.8 Out of 5.0",
    "hero_one_thing_heading": "HEM HERO™ THE ONE THING THAT WORKS",
    "hero_natural_heading": "MADE WITH 100% SAFE, NATURAL INGREDIENTS",
    "alt_ingredients": "ingredients",
    "products_manufactured_heading": "Where Are Hem Healer® Products Manufactured?",
    "dosage_heading": "SIMPLY TAKE 1 CAPSULE IN THE MORNING",
    "dosage_subheading": "and 2 in the evening with food",
    "alt_hem_hero_facts": "hem hero facts",
