    "testimonial2_author": "Semo",
    "how_it_works_heading": "How Hem Hero® Works",
    "comparison_heading": "Hem Hero® vs. Creams",
    "comparison_description": "We believe in treating the root cause of hemorrhoids-not just masking symptoms. Here's how Hem Hero® stacks up:",
    "comparison_hem_hero": "Hem Hero®",
